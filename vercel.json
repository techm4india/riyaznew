{
  "version": 2,

  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/engineering",
      "destination": "/divisions/engineering"
    },
    {
      "source": "/solutions",
      "destination": "/divisions/solutions"
    },
    {
      "source": "/space",
      "destination": "/divisions/space"
    },
    {
      "source": "/schools",
      "destination": "/divisions/schools"
    },
    {
      "source": "/about",
      "destination": "/pages/about"
    },
    {
      "source": "/programs",
      "destination": "/pages/programs"
    },
    {
      "source": "/research",
      "destination": "/pages/research"
    },
    {
      "source": "/impact",
      "destination": "/pages/impact"
    },
    {
      "source": "/careers",
      "destination": "/pages/careers"
    },
    {
      "source": "/contact",
      "destination": "/pages/contact"
    },
    {
      "source": "/ecosystem",
      "destination": "/pages/ecosystem"
    },
    {
      "source": "/vision",
      "destination": "/pages/vision"
    },
    {
      "source": "/login",
      "destination": "/pages/login"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin"
    }
  ],

  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
