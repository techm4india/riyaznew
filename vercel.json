{
  "version": 2,

  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/engineering",
      "destination": "/engineering.html"
    },
    {
      "source": "/solutions",
      "destination": "/solutions.html"
    },
    {
      "source": "/space",
      "destination": "/space.html"
    },
    {
      "source": "/schools",
      "destination": "/schools.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/programs",
      "destination": "/programs.html"
    },
    {
      "source": "/research",
      "destination": "/research.html"
    },
    {
      "source": "/impact",
      "destination": "/impact.html"
    },
    {
      "source": "/careers",
      "destination": "/careers.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/ecosystem",
      "destination": "/ecosystem.html"
    },
    {
      "source": "/vision",
      "destination": "/vision.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],

  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
