{
  "version": 2,

  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/engineering",
      "destination": "/divisions/engineering.html"
    },
    {
      "source": "/solutions",
      "destination": "/divisions/solutions.html"
    },
    {
      "source": "/space",
      "destination": "/divisions/space.html"
    },
    {
      "source": "/schools",
      "destination": "/divisions/schools.html"
    },
    {
      "source": "/about",
      "destination": "/pages/about.html"
    },
    {
      "source": "/programs",
      "destination": "/pages/programs.html"
    },
    {
      "source": "/research",
      "destination": "/pages/research.html"
    },
    {
      "source": "/impact",
      "destination": "/pages/impact.html"
    },
    {
      "source": "/careers",
      "destination": "/pages/careers.html"
    },
    {
      "source": "/contact",
      "destination": "/pages/contact.html"
    },
    {
      "source": "/ecosystem",
      "destination": "/pages/ecosystem.html"
    },
    {
      "source": "/vision",
      "destination": "/pages/vision.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    }
  ],

  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
